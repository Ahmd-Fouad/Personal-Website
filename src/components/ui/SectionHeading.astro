---
interface Props {
  lead: string;
  highlight: string;
  class?: string;
}
const { lead, highlight, class: className = '' } = Astro.props;
---

<h2
  class={`section-heading reveal text-center font-heading text-4xl font-bold sm:text-5xl ${className}`}
>
  {lead}{' '}
  <span class="text-gradient">{highlight}</span>
</h2>
