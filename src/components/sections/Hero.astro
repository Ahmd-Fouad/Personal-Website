---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { site, hero } from '@data/site';
import heroImg from '../../assets/Hero-PImg.png';

const headlineCharacterCount = Math.max(...hero.headlines.map((title) => title.length));
const headlineLabels = hero.headlines.join(' / ');
const heroImageWidths = [212, 240, 320, 360, 424, 480, 640, 720, 848, 960, 1122];
---

<section
  id="home"
  class="hero-gradient relative flex min-h-screen items-center justify-center overflow-hidden"
>
  <div
    class="hero-inner container-x z-10 flex flex-col-reverse items-center justify-center gap-10 py-28 text-center 992:flex-row 992:justify-between 992:gap-12 992:py-24 992:text-start"
  >
    <div class="hero-copy w-full max-w-[680px] 992:flex-1">
      <h1
        class="hero-el hero-name text-center font-heading text-3xl font-bold sm:text-4xl 992:text-start xl:text-5xl"
      >
        {hero.greeting}
      </h1>
      <h2
        class="hero-el hero-title text-gradient text-center font-bold 992:text-start"
        aria-label={headlineLabels}
      >
        <span
          class="typewriter-title"
          data-typewriter
          data-text={hero.headline}
          data-texts={hero.headlines.join('|')}
          style={`--typewriter-ch: ${headlineCharacterCount}`}
          aria-hidden="true"
        >
          <span class="typewriter-text" data-typewriter-text>{hero.headline}</span>
          <span class="typewriter-cursor" aria-hidden="true"></span>
        </span>
      </h2>
      <p
        class="hero-el hero-tagline mx-auto max-w-[650px] text-center text-base text-text-muted sm:text-lg 992:mx-0 992:text-start xl:text-2xl"
      >
        {hero.tagline}
      </p>
      <div
        class="hero-el hero-actions flex w-full flex-wrap items-center justify-center gap-3 sm:gap-4 992:justify-start"
      >
        <a
          href="#contact"
          class="neu-btn hero-action w-full max-w-[15rem] rounded-full py-3 text-center text-lg font-semibold 480:w-52"
        >
          Contact Me
        </a>
        <a
          href={site.cvPath}
          download={site.cvDownloadName}
          class="neu-btn hero-action download-cv inline-flex w-full max-w-[15rem] items-center justify-center gap-2 rounded-full py-3 text-lg font-semibold 480:w-52"
        >
          Download CV
          <Icon
            name="fa6-solid:arrow-down"
            class="download-icon h-4 w-4"
            aria-hidden="true"
          />
        </a>
      </div>
    </div>

    <div
      class="hero-el hero-img w-[min(64vw,13.25rem)] shrink-0 480:w-[15rem] 992:w-[20rem] lg:w-[22.5rem] xl:w-[26.5rem] 2xl:w-[30rem]"
    >
      <div class="hero-img-frame">
      <Image
        src={heroImg}
        alt={`${site.name} — ${site.role}`}
        width={1122}
        height={1402}
        widths={heroImageWidths}
        sizes="(min-width: 1536px) 480px, (min-width: 1280px) 424px, (min-width: 1024px) 360px, (min-width: 992px) 320px, (min-width: 480px) 240px, 64vw"
        format="webp"
        quality={88}
        priority
        class="hero-portrait"
      />
      </div>
    </div>
  </div>

  <a
    href="#about"
    class="absolute bottom-10 left-1/2 z-10 -translate-x-1/2 animate-bounce text-text transition-transform duration-300 hover:scale-125 hover:text-primary-text"
    aria-label="Scroll to About section"
  >
    <Icon name="fa6-solid:chevron-down" class="h-6 w-6" aria-hidden="true" />
  </a>
</section>
