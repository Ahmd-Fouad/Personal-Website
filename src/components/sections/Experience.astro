---
import { Icon } from 'astro-icon/components';
import SectionHeading from '../ui/SectionHeading.astro';
import { experience } from '@data/experience';
---

<section id="experience" class="section-pad relative">
  <div class="container-x">
    <SectionHeading lead="Work" highlight="Experience" />

    <div class="mx-auto max-w-5xl space-y-6 sm:space-y-8">
      {
        experience.map((job, i) => (
          <div class="reveal flex flex-col md:flex-row md:gap-6">
            <div class="z-10 shrink-0 -translate-x-4 translate-y-6 md:mt-1 md:translate-x-0 md:translate-y-0">
              <div class="neu-chip grid h-14 w-14 place-items-center rounded-full lg:h-16 lg:w-16">
                <span class="text-2xl font-bold text-primary-text">{i + 1}</span>
              </div>
            </div>
            <div class="neu-card neu-card-hover relative grow rounded-3xl p-6 xl:p-8">
              <div class="flex flex-wrap items-center justify-between gap-x-3 gap-y-1">
                <h3 class="text-xl font-bold md:text-2xl">{job.company}</h3>
                <span class="text-sm uppercase tracking-wider text-primary-text">
                  {job.period}
                </span>
              </div>
              <p class="text-sm text-text-faint">{job.location}</p>
              <p class="mb-4 text-lg font-semibold text-primary-text md:text-xl">{job.role}</p>
              <ul class="space-y-2 text-text-muted">
                {job.points.map((point) => (
                  <li class="flex items-baseline gap-2">
                    <Icon
                      name="fa6-solid:chevron-right"
                      class="mt-1 h-3 w-3 shrink-0 text-primary-text"
                      aria-hidden="true"
                    />
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
              {job.keyProjects && (
                <p class="mt-4 text-sm text-text-muted">
                  <span class="font-semibold text-primary-text">Key Projects: </span>
                  {job.keyProjects.join(' · ')}
                </p>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
