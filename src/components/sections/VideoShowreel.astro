---
import { Icon } from 'astro-icon/components';
import { videoSlides } from '@data/education';
---

<div class="section-divider"></div>
<section class="relative h-[360px] w-full overflow-hidden bg-primary" aria-label="Project showreel">
  <div id="video-track" class="scrollbar-none flex h-full snap-x snap-mandatory overflow-x-auto scroll-smooth">
    {
      videoSlides.map((slide) => (
        <div class="video-slide relative h-full w-full shrink-0 snap-center" data-video-slide>
          {/*
            preload="none", no `autoplay`, and a data-only source: nothing is
            fetched on initial page load. JS attaches the source only after an
            explicit activation of the play control.
          */}
          <video
            class="video-el h-full w-full object-cover"
            muted
            loop
            playsinline
            preload="none"
            aria-label={slide.label}
          >
            <source data-src={slide.src} type="video/mp4" />
            Your browser does not support the video tag.
          </video>
          <div class="pointer-events-none absolute inset-0 z-10 bg-ink/25"></div>
          {/* Branded poster placeholder — shown until playback begins so the
              slide is never a blank/black box while media is unloaded. */}
          <div
            class="video-poster pointer-events-none absolute inset-0 z-20 bg-primary"
            data-video-poster
            aria-hidden="true"
          >
          </div>
          <button
            type="button"
            class="video-toggle absolute left-1/2 top-1/2 z-30 grid h-16 w-16 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full bg-slate/70 text-primary shadow-lg transition-transform duration-300 hover:scale-105 hover:bg-slate"
            data-video-toggle
            aria-label={`Play ${slide.label}`}
            aria-pressed="false"
          >
            <Icon name="fa6-solid:play" class="video-icon-play h-6 w-6 ps-0.5" aria-hidden="true" />
            <Icon name="fa6-solid:pause" class="video-icon-pause hidden h-6 w-6" aria-hidden="true" />
          </button>
          <button
            type="button"
            class="video-mute absolute bottom-4 end-4 z-30 h-10 w-10 place-items-center rounded-full bg-slate/70 text-primary shadow-lg transition-transform duration-300 hover:scale-105 hover:bg-slate"
            data-video-mute
            aria-label={`Unmute ${slide.label}`}
          >
            <Icon name="fa6-solid:volume-xmark" class="video-icon-muted h-4 w-4" aria-hidden="true" />
            <Icon name="fa6-solid:volume-high" class="video-icon-sound hidden h-4 w-4" aria-hidden="true" />
          </button>
          <button
            type="button"
            class="video-fs absolute bottom-4 end-16 z-30 grid h-10 w-10 place-items-center rounded-full bg-slate/70 text-primary shadow-lg transition-transform duration-300 hover:scale-105 hover:bg-slate"
            data-video-fullscreen
            aria-label={`Enter full screen: ${slide.label}`}
          >
            <Icon name="fa6-solid:expand" class="video-icon-expand h-4 w-4" aria-hidden="true" />
            <Icon name="fa6-solid:compress" class="video-icon-compress hidden h-4 w-4" aria-hidden="true" />
          </button>
          {/* Small always-accessible status line; JS fills it while media is
              loading or when a source fails, so the slide is never silent. */}
          <p
            class="video-status absolute bottom-4 start-4 z-30 rounded-full bg-slate/80 px-3 py-1 text-xs font-semibold text-cream"
            data-video-status
            role="status"
            hidden
          >
          </p>
        </div>
      ))
    }
  </div>

  <button
    type="button"
    id="video-prev"
    class="absolute start-3 top-1/2 z-40 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-full bg-slate/70 text-primary transition-transform duration-300 hover:scale-105 hover:bg-slate"
    aria-label="Previous video"
  >
    <Icon name="fa6-solid:chevron-left" class="h-4 w-4" aria-hidden="true" />
  </button>
  <button
    type="button"
    id="video-next"
    class="absolute end-3 top-1/2 z-40 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-full bg-slate/70 text-primary transition-transform duration-300 hover:scale-105 hover:bg-slate"
    aria-label="Next video"
  >
    <Icon name="fa6-solid:chevron-right" class="h-4 w-4" aria-hidden="true" />
  </button>
</section>
<div class="section-divider"></div>

<style>
  /* The poster leaves only when playback has an actual frame to show
     (is-playing + has-frame, both JS-synced), so a buffering video never
     exposes a blank/black box. Kept in CSS so state is a class toggle. */
  .video-slide.is-playing.has-frame .video-poster {
    opacity: 0;
  }
  .video-poster {
    transition: opacity 0.3s ease;
  }
  .video-slide.is-playing .video-icon-play {
    display: none;
  }
  .video-slide.is-playing .video-icon-pause {
    display: block;
  }
  /* Subtle loading state around the existing play/pause control while the
     source is buffering (JS toggles is-waiting on the slide). */
  .video-toggle::after {
    content: "";
    position: absolute;
    inset: -0.4rem;
    border-radius: 999px;
    border: 3px solid transparent;
    border-top-color: var(--accent);
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }
  .video-slide.is-waiting .video-toggle::after {
    opacity: 1;
    animation: videoSpin 0.9s linear infinite;
  }
  @keyframes videoSpin {
    to {
      transform: rotate(360deg);
    }
  }
  /* Idle controls are subtle over the ambient reel but stay operable; they
     lift to full opacity on hover/focus for a clearly visible affordance. */
  .video-slide.is-playing .video-toggle,
  .video-slide.is-playing .video-mute,
  .video-slide.is-playing .video-fs {
    opacity: 0.55;
  }
  .video-toggle:hover,
  .video-toggle:focus-visible,
  .video-mute:hover,
  .video-mute:focus-visible,
  .video-fs:hover,
  .video-fs:focus-visible {
    opacity: 1;
  }
  /* Native fullscreen on the slide keeps the custom controls overlaid; the
     video letterboxes instead of cropping while it fills the screen. */
  .video-slide:fullscreen {
    background: #000;
  }
  .video-slide:fullscreen .video-el {
    object-fit: contain;
  }
  .video-slide.is-fullscreen .video-icon-expand {
    display: none;
  }
  .video-slide.is-fullscreen .video-icon-compress {
    display: block;
  }
  /* The mute toggle only matters during playback; it appears with the pause
     control and swaps its icon with the slide's is-muted state (JS-synced). */
  .video-mute {
    display: none;
  }
  .video-slide.is-playing .video-mute {
    display: grid;
  }
  .video-slide:not(.is-muted) .video-icon-muted {
    display: none;
  }
  .video-slide:not(.is-muted) .video-icon-sound {
    display: block;
  }
</style>
