---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import SectionHeading from '../ui/SectionHeading.astro';
import { projects } from '@data/projects';
import type { Project } from '@data/projects';

const projectCardWidths = [320, 480, 640, 800, 960, 1200, 1600, 2048];
const projectModalWidths = [640, 900, 1200, 1440, 1600, 2048];
const projectImageQuality = 92;
const imageWidths = (image: { width: number }, candidates: number[]) =>
  Array.from(new Set([...candidates.filter((width) => width <= image.width), image.width])).sort(
    (a, b) => a - b,
  );
const hasPublicImage = (project: Project): project is Extract<Project, { image: string }> =>
  typeof project.image === 'string';
---

<section id="projects" class="relative bg-bg-2/40 py-20">
  <div class="section-divider mb-16"></div>
  <div class="container-x">
    <SectionHeading lead="Featured" highlight="Projects" />

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {
        projects.map((project) => (
          <article class="neu-card neu-card-hover reveal group cursor-pointer overflow-hidden rounded-2xl">
            <div class="relative h-56 overflow-hidden">
              {
                hasPublicImage(project) ? (
                  <Image
                    src={project.image}
                    alt={project.title}
                    width={project.imageWidth}
                    height={project.imageHeight}
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                ) : (
                  <Image
                    src={project.image}
                    alt={project.title}
                    widths={imageWidths(project.image, projectCardWidths)}
                    sizes="(min-width: 1280px) 25vw, (min-width: 768px) 50vw, 100vw"
                    quality={projectImageQuality}
                    loading="lazy"
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                )
              }
              <div class="absolute inset-0 flex items-center justify-center bg-ink/70 opacity-0 backdrop-blur-[2px] transition-opacity duration-300 group-hover:opacity-100">
                <button
                  type="button"
                  class="neu-btn-accent detail-btn rounded-full px-6 py-3 font-semibold"
                  data-modal-target={project.id}
                  aria-haspopup="dialog"
                >
                  View Details
                </button>
              </div>
            </div>
            <div class="p-4 pt-3">
              <h3 class="mb-2 text-center text-2xl font-semibold text-primary">{project.title}</h3>
              <dl class="text-[15px]">
                {[
                  ['Location', project.location],
                  ['Company', project.companyShort],
                  ['Role', project.role],
                  ['Year', project.year],
                ].map(([label, value]) => (
                  <div class="mb-1 flex gap-2">
                    <dt class="w-20 shrink-0 font-semibold text-primary">{label}:</dt>
                    <dd class="text-text-muted">{value}</dd>
                  </div>
                ))}
              </dl>
            </div>
          </article>
        ))
      }
    </div>
  </div>
  <div class="section-divider mt-16"></div>
</section>

<!-- Project detail modals -->
{
  projects.map((project) => (
    <div
      id={`project-modal-${project.id}`}
      class="project-modal fixed inset-0 z-[60] hidden items-center justify-center bg-ink/60 p-4 backdrop-blur-sm"
      role="dialog"
      aria-modal="true"
      aria-labelledby={`project-modal-title-${project.id}`}
    >
      <div class="neu-card flex max-h-[92vh] w-full max-w-4xl flex-col overflow-hidden rounded-3xl">
        <header class="flex items-center justify-between border-b border-border px-6 py-4 sm:px-8">
          <h3 id={`project-modal-title-${project.id}`} class="text-2xl font-bold">
            {project.modalTitle ?? project.title}
          </h3>
          <button
            type="button"
            class="modal-close grid h-9 w-9 place-items-center rounded-full text-primary transition-transform duration-300 hover:scale-110"
            aria-label="Close dialog"
          >
            <Icon name="fa6-solid:xmark" class="h-5 w-5" aria-hidden="true" />
          </button>
        </header>
        <div class="overflow-y-auto px-6 py-5">
          <div class="mb-4 overflow-hidden rounded-2xl">
            {
              hasPublicImage(project) ? (
                <Image
                  src={project.image}
                  alt={`${project.title} cover`}
                  width={project.imageWidth}
                  height={project.imageHeight}
                  loading="lazy"
                  class="h-64 w-full object-cover sm:h-72"
                />
              ) : (
                <Image
                  src={project.image}
                  alt={`${project.title} cover`}
                  widths={imageWidths(project.image, projectModalWidths)}
                  sizes="(min-width: 768px) 800px, 100vw"
                  quality={projectImageQuality}
                  loading="lazy"
                  class="h-64 w-full object-cover sm:h-72"
                />
              )
            }
          </div>
          <p class="mb-5 text-text-muted">{project.description}</p>
          <div class="grid gap-6 md:grid-cols-3">
            <div class="md:col-span-1">
              <h4 class="mb-2 text-xl font-bold text-primary">Project Details</h4>
              <dl class="space-y-2 text-text-muted">
                {[
                  ['Location', project.location],
                  ['Company', project.company],
                  ['Role', project.role],
                  ['Year', project.year],
                ].map(([label, value]) => (
                  <div class="flex gap-2">
                    <dt class="w-20 shrink-0 text-text">{label}:</dt>
                    <dd>{value}</dd>
                  </div>
                ))}
              </dl>
            </div>
            <div class="md:col-span-2">
              <h4 class="mb-2 text-xl font-bold text-primary">My Role</h4>
              <ul class="list-inside list-disc space-y-1 text-text-muted">
                {project.contributions.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  ))
}
