---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import SectionHeading from '../ui/SectionHeading.astro';
import { projects } from '@data/projects';

// Card slot tops out around 767 CSS px (100vw below md) and the modal slot at
// 800px, so 1600w covers 2× density on both; wider variants are never selected.
const projectCardWidths = [320, 480, 640, 960, 1280, 1600];
const projectModalWidths = [640, 800, 1200, 1600];
const projectImageQuality = 92;
const imageWidths = (image: { width: number }, candidates: number[]) => {
  const within = candidates.filter((width) => width <= image.width);
  return within.length ? within : [image.width];
};
---

<section id="projects" class="section-pad relative bg-bg-2/40">
  <div class="section-divider absolute inset-x-0 top-0"></div>
  <div class="container-x">
    <SectionHeading lead="Featured" highlight="Projects" />

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {
        projects.map((project) => (
          <article class="neu-card neu-card-hover reveal group overflow-hidden rounded-2xl">
            <div class="relative h-56 overflow-hidden">
              <Image
                src={project.image}
                alt={project.title}
                widths={imageWidths(project.image, projectCardWidths)}
                sizes="(min-width: 1280px) 25vw, (min-width: 768px) 50vw, 100vw"
                quality={projectImageQuality}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div data-modal-overlay class="absolute inset-0 flex items-center justify-center bg-ink/70 opacity-0 backdrop-blur-[2px] transition-opacity duration-300 group-hover:opacity-100 group-focus-within:opacity-100 pointer-coarse:opacity-100">
                <button
                  type="button"
                  class="neu-btn-accent detail-btn rounded-full px-6 py-3 font-semibold"
                  data-modal-target={project.id}
                  aria-haspopup="dialog"
                >
                  View Details
                </button>
              </div>
            </div>
            <div class="p-4 pt-3">
              <h3 class="mb-2 text-center text-2xl font-semibold text-primary-text">{project.title}</h3>
              <dl class="text-[15px]">
                {[
                  ['Location', project.location],
                  ['Company', project.companyShort],
                  ['Role', project.role],
                  ['Year', project.year],
                ].map(([label, value]) => (
                  <div class="mb-1 flex gap-2">
                    <dt class="w-20 shrink-0 font-semibold text-primary-text">{label}:</dt>
                    <dd class="text-text-muted">{value}</dd>
                  </div>
                ))}
              </dl>
              <noscript>
                <details class="mt-4 border-t border-border pt-3 text-sm">
                  <summary class="cursor-pointer font-semibold text-primary-text">Project details</summary>
                  <p class="mt-3 text-text-muted">{project.description}</p>
                  <h4 class="mb-1 mt-3 font-semibold text-primary-text">My Role</h4>
                  <ul class="list-inside list-disc space-y-1 text-text-muted">
                    {project.contributions.map((item) => <li>{item}</li>)}
                  </ul>
                </details>
              </noscript>
            </div>
          </article>
        ))
      }
    </div>
  </div>
  <div class="section-divider absolute inset-x-0 bottom-0"></div>
</section>

<!-- Project detail modals -->
{
  projects.map((project) => (
    <div
      id={`project-modal-${project.id}`}
      class="project-modal fixed inset-0 z-[60] hidden items-center justify-center bg-ink/60 p-4 backdrop-blur-sm"
      role="dialog"
      aria-modal="true"
      aria-labelledby={`project-modal-title-${project.id}`}
    >
      <div class="neu-card flex w-full max-w-4xl flex-col overflow-hidden rounded-3xl">
        <header class="flex items-center justify-between border-b border-border px-6 py-3 sm:px-8">
          <h3 id={`project-modal-title-${project.id}`} class="text-2xl font-bold">
            {project.modalTitle ?? project.title}
          </h3>
          <button
            type="button"
            class="modal-close grid h-9 w-9 place-items-center rounded-full text-primary-text transition-transform duration-300 hover:scale-110"
            aria-label="Close dialog"
          >
            <Icon name="fa6-solid:xmark" class="h-5 w-5" aria-hidden="true" />
          </button>
        </header>
        <div
          class="modal-scroll min-h-0 overflow-y-auto px-6 py-4"
          data-modal-scroll
          tabindex="0"
          role="region"
          aria-label={`${project.modalTitle ?? project.title} details`}
        >
          {/* Progressive cover: the already-cached card image is shown as an
              instant preview (JS fills data-modal-preview from the trigger's
              card <img>) while the modal-sized candidate loads underneath and
              fades in once decoded. The final image's fixed height keeps the
              box stable in every state. */}
          <div class="modal-media relative mb-4 overflow-hidden rounded-2xl" data-modal-media>
            <img data-modal-preview alt="" aria-hidden="true" class="modal-media-preview" hidden />
            <Image
              src={project.image}
              alt={`${project.title} cover`}
              widths={imageWidths(project.image, projectModalWidths)}
              sizes="(min-width: 768px) 800px, 100vw"
              quality={projectImageQuality}
              loading="lazy"
              decoding="async"
              data-modal-final
              class="modal-media-final h-[clamp(10rem,32vh,18rem)] w-full object-cover"
            />
          </div>
          <p class="mb-4 text-text-muted">{project.description}</p>
          <div class="grid gap-6 md:grid-cols-3">
            <div class="md:col-span-1">
              <h4 class="mb-2 text-xl font-bold text-primary-text">Project Details</h4>
              <dl class="space-y-2 text-text-muted">
                {[
                  ['Location', project.location],
                  ['Company', project.company],
                  ['Role', project.role],
                  ['Year', project.year],
                ].map(([label, value]) => (
                  <div class="flex gap-2">
                    <dt class="w-20 shrink-0 text-text">{label}:</dt>
                    <dd>{value}</dd>
                  </div>
                ))}
              </dl>
            </div>
            <div class="md:col-span-2">
              <h4 class="mb-2 text-xl font-bold text-primary-text">My Role</h4>
              <ul class="list-inside list-disc space-y-1 text-text-muted">
                {project.contributions.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  ))
}
