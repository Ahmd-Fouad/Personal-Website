---
import SectionHeading from '../ui/SectionHeading.astro';
import { process } from '@data/skills';
---

<section id="process" class="relative py-20">
  <div class="container-x">
    <SectionHeading lead="Work" highlight="Process" />

    <div class="mx-auto max-w-5xl space-y-4 sm:space-y-5">
      {
        process.map((step, i) => (
          <div class="reveal flex flex-col sm:flex-row sm:items-center sm:gap-6">
            <div class="z-10 shrink-0 -translate-x-4 translate-y-6 sm:translate-x-0 sm:translate-y-0">
              <div class="neu-chip grid h-14 w-14 place-items-center rounded-full lg:h-16 lg:w-16">
                <span class="text-2xl font-bold text-primary">{i + 1}</span>
              </div>
            </div>
            <div class="neu-card neu-card-hover flex-1 rounded-2xl p-6 text-center 480:text-start">
              <h3 class="mb-2 text-xl font-bold sm:text-2xl">{step.title}</h3>
              <p class="text-text-muted">{step.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
