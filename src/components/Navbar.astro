---
import { Icon } from 'astro-icon/components';
import { site, navLinks } from '@data/site';
import ThemeToggle from './ui/ThemeToggle.astro';

// Desktop keeps the compact pill nav; Contact is the CTA and Education is mobile-only.
const desktopLinks = navLinks.filter((l) => l.href !== '#contact' && l.href !== '#education');
---

<!-- Scroll reading-progress bar -->
<div
  id="scroll-progress"
  class="fixed left-0 top-0 z-[100] h-[3px] w-0 bg-primary"
  aria-hidden="true"
>
</div>

<nav
  id="navbar"
  class="fixed left-0 top-0 z-50 w-full transition-all duration-300"
  aria-label="Primary"
>
  <div class="container-x flex items-center justify-between py-4">
    <a href="#home" class="font-logo text-2xl font-bold text-gradient">
      {site.shortName}
    </a>

    <!-- Desktop nav -->
    <div id="desktop-nav" class="relative hidden lg:block">
      <span id="nav-active-indicator" aria-hidden="true"></span>
      <ul class="relative z-10 flex items-center gap-2 text-sm uppercase tracking-wider xl:gap-3">
        {
          desktopLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="nav-link relative block rounded-full px-3 py-2 text-text-muted transition-colors duration-300 hover:text-primary-text xl:px-4"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <a
        href="#contact"
        class="neu-btn nav-cta-link hidden rounded-full px-5 py-2 text-sm uppercase tracking-wider lg:block"
      >
        Get in Touch
      </a>
      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="neu-btn grid h-10 w-10 place-items-center rounded-full text-primary-text lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="fa6-solid:bars" class="menu-bars h-4 w-4" aria-hidden="true" />
        <Icon name="fa6-solid:xmark" class="menu-x hidden h-4 w-4" aria-hidden="true" />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-border bg-bg/95 backdrop-blur-xl lg:hidden"
  >
    <ul class="container-x flex flex-col gap-2 py-4 text-center">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-nav-link block rounded-xl py-3 text-text-muted transition-colors duration-300 hover:text-primary-text"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  #navbar.scrolled {
    background-color: color-mix(in oklab, var(--bg) 88%, transparent);
    backdrop-filter: blur(14px);
    box-shadow: 0 10px 30px -12px var(--shadow-dark);
    border-bottom: 1px solid var(--border);
  }
  #nav-active-indicator {
    position: absolute;
    left: 0;
    top: 50%;
    z-index: 0;
    width: var(--nav-indicator-w, 0px);
    height: 2.35rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background:
      radial-gradient(circle at 28% 18%, color-mix(in oklab, var(--accent) 28%, transparent), transparent 38%),
      color-mix(in oklab, var(--accent) 13%, transparent);
    box-shadow: var(--nu-inset-sm), 0 8px 24px -18px var(--accent);
    opacity: 0;
    transform: translate3d(var(--nav-indicator-x, 0px), -50%, 0) scaleX(0.96);
    transform-origin: center;
    transition:
      transform 0.48s cubic-bezier(0.22, 1, 0.36, 1),
      width 0.48s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.25s ease;
    pointer-events: none;
  }
  #nav-active-indicator.is-ready {
    opacity: 1;
    transform: translate3d(var(--nav-indicator-x, 0px), -50%, 0) scaleX(1);
  }
  .nav-link {
    isolation: isolate;
  }
  .nav-link.active {
    color: var(--accent-text);
    text-shadow: 0 0 18px color-mix(in oklab, var(--accent) 34%, transparent);
  }
  .mobile-nav-link.active {
    background: color-mix(in oklab, var(--accent) 13%, transparent);
    color: var(--accent-text);
    box-shadow: var(--nu-inset-sm);
  }
  .nav-cta-link.active {
    color: var(--accent-text);
    box-shadow: var(--nu-inset-sm), 0 0 18px -10px var(--accent);
  }
  @media (prefers-reduced-motion: reduce) {
    #nav-active-indicator {
      transition-duration: 0.001ms;
    }
  }
  #mobile-menu-btn[aria-expanded='true'] .menu-bars {
    display: none;
  }
  #mobile-menu-btn[aria-expanded='true'] .menu-x {
    display: block;
  }
</style>
